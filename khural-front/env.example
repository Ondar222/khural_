## Frontend environment variables (Vite)
##
## By default in dev (localhost) the app uses "/api" and Vite proxies it (see vite.config.js).
## So you usually DON'T need VITE_API_BASE_URL locally.

# Для продакшена укажите URL бекенда — календарь, новости, депутаты будут с бэкенда.
# Production: copy to .env or set in Vercel/hosting. Фронт: https://khural.yurta.site
# На бэкенде (someshit.yurta.site) в CORS нужно разрешить origin: https://khural.yurta.site
VITE_API_BASE_URL=https://someshit.yurta.site

# Локальная разработка (если нужен прямой доступ к бэкенду):
# VITE_API_BASE_URL=http://localhost:4000

# API календаря (события). Если не задано — используется VITE_API_BASE_URL.
# Чтобы созданные события и переводы слайдера (TY) были видны на ВСЕХ устройствах:
# 1) Все клиенты должны использовать один и тот же URL бэкенда (тот же .env на деплое).
# 2) Бэкенд должен сохранять в БД: события (POST/calendar) и слайды с titleTy/descriptionTy (PATCH /slider).
# 3) Бэкенд должен отдавать в GET /calendar и GET /slider эти данные (не только в localStorage).
# VITE_CALENDAR_API_BASE_URL=https://someshit.yurta.site

# Optional: override base URL for files (when backend returns relative "/files/..." links)
# VITE_FILES_BASE_URL=https://someshit.yurta.site

# Optional: storage keys (defaults: access_token / refresh_token; legacy auth_token is also supported)
# VITE_API_TOKEN_STORAGE_KEY=access_token
# VITE_API_REFRESH_TOKEN_STORAGE_KEY=refresh_token




